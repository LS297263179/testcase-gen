# ============================================================
# AI 测试用例生成器 - 配置文件
# 复制此文件为 config.yaml 并填入你的 API 信息
# ============================================================

# ---------- 安全配置 ----------
# 用于 Flask session 加密，重启后保持登录状态
# 请替换为你自己生成的随机字符串（可以用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
secret_key: "your-random-secret-key-here"

# ---------- 测试用例生成模型 ----------
generate:
  api_type: "anthropic"                                    # anthropic / openai
  base_url: "https://token-plan-cn.xiaomimimo.com/anthropic"
  api_key: "your-api-key-here"
  model: "mimo-v2.5-pro"
  temperature: 0.3
  max_tokens: 4096
  max_retries: 3

# ---------- 测试用例评审模型 ----------
review:
  enabled: false
  api_type: "openai"
  base_url: "https://api.deepseek.com"
  api_key: "your-api-key-here"
  model: "deepseek-chat"
  temperature: 0.3
  max_tokens: 4096
  max_retries: 3

# ---------- 输出配置 ----------
output:
  dir: "./output"
  format: "all"

# ---------- 用例配置 ----------
testcase:
  default_priority: "P1"
  max_testcases: 100        # 单次生成最大用例数
  case_types:
    - "功能测试"
    - "边界测试"
    - "异常测试"
    - "兼容性测试"
    - "性能测试"

# 数据库文件自动保存在 data/data.db，无需配置
# 偏好规则自动管理，无需配置
