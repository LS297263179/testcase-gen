# ============================================================
# AI 测试用例生成器 - 配置文件
# 复制此文件为 config.yaml 并填入你的 API 信息
# ============================================================

# ---------- 安全配置 ----------
# 用于 Flask session 加密，重启后保持登录状态
# 优先从环境变量 FLASK_SECRET_KEY 读取，此值作为 fallback
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
secret_key: "your-random-secret-key-here"

# ---------- 测试用例生成模型 ----------
# 用于根据需求文档生成测试用例，建议用能力较强的模型
generate:
  api_type: "openai"                                         # anthropic / openai
  base_url: "https://token-plan-cn.xiaomimimo.com/v1"
  api_key: "your-api-key-here"
  model: "mimo-v2.5"
  image_model: "mimo-v2.5"                                   # 图片识别模型（可选，留空则不使用）
  temperature: 0.3
  max_tokens: 4096
  max_retries: 3
  enable_thinking: true                                      # 是否启用思考模式

# ---------- 测试用例评审模型 ----------
# 如不需要单独配置，将 enabled 设为 false，会复用上面的生成模型
review:
  enabled: false
  api_type: "openai"
  base_url: "https://api.deepseek.com"
  api_key: "your-api-key-here"
  model: "deepseek-chat"
  temperature: 0.3
  max_tokens: 4096
  max_retries: 3

# ---------- 输出配置 ----------
output:
  dir: "./output"
  format: "all"                                              # excel / markdown / all

# ---------- 用例配置 ----------
testcase:
  default_priority: "P1"                                     # P0(阻塞) / P1(严重) / P2(一般) / P3(轻微)
  max_testcases: 100                                         # 单次生成最大用例数
  case_types:
    - "功能测试"
    - "边界测试"
    - "异常测试"
    - "兼容性测试"
    - "性能测试"

# 数据库文件自动保存在 data/data.db，无需配置
# 偏好规则自动管理，无需配置
