# ============================================================
# AI 测试用例生成器 - 配置文件
# 复制此文件为 config.yaml 并填入你的 API 信息
# ============================================================

# ---------- 测试用例生成模型 ----------
generate:
  api_type: "anthropic"                                    # anthropic / openai
  base_url: "https://token-plan-cn.xiaomimimo.com/anthropic"
  api_key: "your-api-key-here"
  model: "mimo-v2.5-pro"
  temperature: 0.3
  max_tokens: 4096
  max_retries: 3

# ---------- 测试用例评审模型 ----------
review:
  enabled: false
  api_type: "openai"
  base_url: "https://api.deepseek.com"
  api_key: "your-api-key-here"
  model: "deepseek-chat"
  temperature: 0.3
  max_tokens: 4096
  max_retries: 3

# ---------- 输出配置 ----------
output:
  dir: "./output"
  format: "all"

# ---------- 用例配置 ----------
testcase:
  default_priority: "P1"
  case_types:
    - "功能测试"
    - "边界测试"
    - "异常测试"
    - "兼容性测试"
    - "性能测试"
